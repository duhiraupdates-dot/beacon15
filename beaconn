package com.hirabeacon.journal;

import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.*;
import javafx.scene.paint.Color;
import javafx.scene.shape.SVGPath;
import javafx.stage.Modality;
import javafx.stage.Stage;
import java.text.SimpleDateFormat;
import java.util.ArrayList;
import java.util.Date;
import java.util.List;
import java.util.stream.Collectors;

/**
 * Hira Beacon Journal - A Native JavaFX & CSS Desktop Publication System.
 * Incorporates an asynchronous-style UI with deep-black styling, gold highlights,
 * and high-fidelity interactive elements.
 */
public class HiraBeaconApp extends Application {

    private List<Article> database = new ArrayList<>();
    private List<String> bookmarkedIds = new ArrayList<>();
    private String activeLanguageFilter = "All";
    private String activeLitStyleFilter = "All";
    private String searchKeyword = "";
    private boolean isEditorMode = false;

    // Layout References
    private BorderPane mainContainer;
    private FlowPane articlesGrid;
    private VBox readerDrawer;
    private ScrollPane gridScrollPane;
    
    // Header UI Elements
    private HBox languageFilterBar;
    private HBox styleFilterBar;
    private Label statCountLabel;
    private Label lockboxStatusLabel;
    private Label bookmarkCountLabel;

    @Override
    public void start(Stage primaryStage) {
        seedInitialDatabase();

        // Root Window Structure
        mainContainer = new BorderPane();
        mainContainer.getStyleClass().add("root-pane");

        VBox topHeader = buildHeader();
        mainContainer.setTop(topHeader);

        gridScrollPane = new ScrollPane();
        gridScrollPane.getStyleClass().add("custom-scroll-pane");
        gridScrollPane.setFitToWidth(true);

        articlesGrid = new FlowPane();
        articlesGrid.getStyleClass().add("articles-grid");
        articlesGrid.setHgap(20);
        articlesGrid.setVgap(20);
        articlesGrid.setPadding(new Insets(20));

        gridScrollPane.setContent(articlesGrid);
        mainContainer.setCenter(gridScrollPane);

        renderArticles();

        // Building the Scene & Applying JavaFX CSS styles
        Scene scene = new Scene(mainContainer, 1100, 750);
        scene.getStylesheets().add(getCssDataUri());

        primaryStage.setTitle("Hira Beacon — Journal of Academic & Creative Inquiry");
        primaryStage.setScene(scene);
        primaryStage.show();
    }

    private VBox buildHeader() {
        VBox headerBox = new VBox(15);
        headerBox.setPadding(new Insets(20, 20, 10, 20));
        headerBox.setAlignment(Pos.CENTER);

        // Standalone Elegant Golden Logo Emblem
        SVGPath logoSvg = new SVGPath();
        logoSvg.setContent("M 50 10 L 15 70 L 40 55 L 50 65 L 65 48 L 85 70 Z M 35 75 C 45 70, 55 75, 50 78 C 45 75, 35 70, 20 75");
        logoSvg.getStyleClass().add("logo-emblem");
        logoSvg.setScaleX(0.8);
        logoSvg.setScaleY(0.8);

        VBox logoWrapper = new VBox(logoSvg);
        logoWrapper.setAlignment(Pos.CENTER);
        logoWrapper.getStyleClass().add("logo-wrapper");

        // Journal Title Metadata
        Label volLabel = new Label("VOLUME IV • ISSUE II");
        volLabel.getStyleClass().add("volume-label");

        Label titleLabel = new Label("HIRA BEACON");
        titleLabel.getStyleClass().add("journal-title");

        Label descLabel = new Label("A critical international platform of academic reviews, contemporary prose, and creative essays.");
        descLabel.getStyleClass().add("journal-desc");
        descLabel.setWrapText(true);
        descLabel.setAlignment(Pos.CENTER);

        // Languages Navigation bar
        languageFilterBar = new HBox(10);
        languageFilterBar.setAlignment(Pos.CENTER);
        updateLanguageBar();

        // Literary Styles Navigation bar
        styleFilterBar = new HBox(10);
        styleFilterBar.setAlignment(Pos.CENTER);
        updateStyleBar();

        // Control Panel HUD (Search, Bookmarks, Write, Locked Editor Desk)
        HBox controlHud = new HBox(12);
        controlHud.setAlignment(Pos.CENTER);
        controlHud.setPadding(new Insets(10, 0, 10, 0));

        TextField searchField = new TextField();
        searchField.setPromptText("Search catalog...");
        searchField.getStyleClass().add("search-field");
        searchField.setPrefWidth(220);
        searchField.textProperty().addListener((obs, oldVal, newVal) -> {
            searchKeyword = newVal.trim().toLowerCase();
            renderArticles();
        });

        Button writeBtn = new Button("Write Post");
        writeBtn.getStyleClass().add("btn-gold");
        writeBtn.setOnAction(e -> openWriteModal());

        Button lockboxBtn = new Button("Unlock Lockbox");
        lockboxBtn.getStyleClass().add("btn-dark");
        lockboxBtn.setOnAction(e -> handleLockboxToggle());

        statCountLabel = new Label("0 Articles");
        statCountLabel.getStyleClass().add("stat-badge");

        lockboxStatusLabel = new Label("Editor: Off");
        lockboxStatusLabel.getStyleClass().add("stat-badge");

        bookmarkCountLabel = new Label("Bookmarks: 0");
        bookmarkCountLabel.getStyleClass().add("stat-badge");

        controlHud.getChildren().addAll(searchField, writeBtn, lockboxBtn, statCountLabel, lockboxStatusLabel, bookmarkCountLabel);

        // Golden Separator Line
        Separator goldDivider = new Separator();
        goldDivider.getStyleClass().add("gold-divider");

        headerBox.getChildren().addAll(logoWrapper, volLabel, titleLabel, descLabel, languageFilterBar, styleFilterBar, controlHud, goldDivider);
        return headerBox;
    }

    private void updateLanguageBar() {
        languageFilterBar.getChildren().clear();
        String[] langs = {"All", "English", "മലയാളം", "العربية", "اردو", "हिन्दी"};
        for (String lang : langs) {
            Button btn = new Button(lang);
            if (lang.equals(activeLanguageFilter)) {
                btn.getStyleClass().add("nav-btn-active");
            } else {
                btn.getStyleClass().add("nav-btn");
            }
            btn.setOnAction(e -> {
                activeLanguageFilter = lang;
                updateLanguageBar();
                renderArticles();
            });
            languageFilterBar.getChildren().add(btn);
        }
    }

    private void updateStyleBar() {
        styleFilterBar.getChildren().clear();
        String[] styles = {"All", "Poem", "Story", "Essay", "Feature", "Another"};
        for (String style : styles) {
            Button btn = new Button(style);
            if (style.equals(activeLitStyleFilter)) {
                btn.getStyleClass().add("nav-btn-active");
            } else {
                btn.getStyleClass().add("nav-btn");
            }
            btn.setOnAction(e -> {
                activeLitStyleFilter = style;
                updateStyleBar();
                renderArticles();
            });
            styleFilterBar.getChildren().add(btn);
        }
    }

    private void renderArticles() {
        articlesGrid.getChildren().clear();

        List<Article> filtered = database.stream()
                .filter(a -> "published".equalsIgnoreCase(a.status))
                .filter(a -> "All".equals(activeLanguageFilter) || getLangCode(activeLanguageFilter).equalsIgnoreCase(a.language))
                .filter(a -> "All".equals(activeLitStyleFilter) || a.litType.equalsIgnoreCase(activeLitStyleFilter))
                .filter(a -> searchKeyword.isEmpty() || 
                             a.title.toLowerCase().contains(searchKeyword) ||
                             a.author.toLowerCase().contains(searchKeyword) ||
                             a.abstractText.toLowerCase().contains(searchKeyword))
                .collect(Collectors.toList());

        for (Article art : filtered) {
            VBox card = new VBox(8);
            card.getStyleClass().add("article-card");
            card.setPadding(new Insets(15));
            card.setPrefWidth(320);
            card.setMaxWidth(340);

            Label typeLabel = new Label(art.litType.toUpperCase() + " • " + art.language);
            typeLabel.getStyleClass().add("card-type-tag");

            Label titleLabel = new Label(art.title);
            titleLabel.getStyleClass().add("card-title");
            titleLabel.setWrapText(true);

            Label absLabel = new Label(art.abstractText);
            absLabel.getStyleClass().add("card-abstract");
            absLabel.setWrapText(true);

            HBox cardFooter = new HBox();
            cardFooter.setAlignment(Pos.CENTER_LEFT);
            Label authorLabel = new Label(art.author);
            authorLabel.getStyleClass().add("card-author");
            
            Region spacer = new Region();
            HBox.setHgrow(spacer, Priority.ALWAYS);

            Button bookmarkBtn = new Button();
            updateBookmarkButtonVisual(bookmarkBtn, art.id);
            bookmarkBtn.setOnAction(e -> {
                toggleBookmark(art.id);
                updateBookmarkButtonVisual(bookmarkBtn, art.id);
                updateStats();
            });

            cardFooter.getChildren().addAll(authorLabel, spacer, bookmarkBtn);

            // Open detail view on card click
            card.setOnMouseClicked(e -> {
                if (e.getClickCount() == 1) {
                    showReaderDrawer(art);
                }
            });

            card.getChildren().addAll(typeLabel, titleLabel, absLabel, cardFooter);
            articlesGrid.getChildren().add(card);
        }

        updateStats();
    }

    private void updateBookmarkButtonVisual(Button btn, String id) {
        if (bookmarkedIds.contains(id)) {
            btn.setText("★ Saved");
            btn.getStyleClass().setAll("btn-saved-active");
        } else {
            btn.setText("☆ Save");
            btn.getStyleClass().setAll("btn-saved");
        }
    }

    private void toggleBookmark(String id) {
        if (bookmarkedIds.contains(id)) {
            bookmarkedIds.remove(id);
        } else {
            bookmarkedIds.add(id);
        }
    }

    private void showReaderDrawer(Article art) {
        readerDrawer = new VBox(15);
        readerDrawer.getStyleClass().add("reader-drawer");
        readerDrawer.setPadding(new Insets(25));
        readerDrawer.setPrefWidth(450);

        HBox drawerHeader = new HBox(10);
        drawerHeader.setAlignment(Pos.CENTER_LEFT);

        Label metaLabel = new Label(art.category.toUpperCase() + " | " + art.language);
        metaLabel.getStyleClass().add("drawer-meta");

        Region spacer = new Region();
        HBox.setHgrow(spacer, Priority.ALWAYS);

        Button closeBtn = new Button("× Close");
        closeBtn.getStyleClass().add("btn-dark");
        closeBtn.setOnAction(e -> mainContainer.setRight(null));

        drawerHeader.getChildren().addAll(metaLabel, spacer, closeBtn);

        Label titleLabel = new Label(art.title);
        titleLabel.getStyleClass().add("drawer-title");
        titleLabel.setWrapText(true);

        Label authorLabel = new Label("By " + art.author + " • " + art.date);
        authorLabel.getStyleClass().add("drawer-author");

        Separator div = new Separator();
        div.getStyleClass().add("gold-divider");

        TextArea contentArea = new TextArea(art.content);
        contentArea.setEditable(false);
        contentArea.setWrapText(true);
        contentArea.getStyleClass().add("drawer-content-area");
        VBox.setVgrow(contentArea, Priority.ALWAYS);

        HBox footerActions = new HBox(10);
        footerActions.setAlignment(Pos.CENTER_RIGHT);

        if (isEditorMode) {
            Button deleteBtn = new Button("Delete Document");
            deleteBtn.getStyleClass().add("btn-danger");
            deleteBtn.setOnAction(e -> {
                confirmDelete(art);
            });
            footerActions.getChildren().add(deleteBtn);
        }

        readerDrawer.getChildren().addAll(drawerHeader, titleLabel, authorLabel, div, contentArea, footerActions);
        mainContainer.setRight(readerDrawer);
    }

    private void confirmDelete(Article art) {
        Stage confirmStage = new Stage();
        confirmStage.initModality(Modality.APPLICATION_MODAL);
        
        VBox box = new VBox(15);
        box.setPadding(new Insets(20));
        box.setAlignment(Pos.CENTER);
        box.getStyleClass().add("root-pane");

        Label warning = new Label("Are you sure you want to delete this piece?");
        warning.getStyleClass().add("drawer-title");

        HBox btns = new HBox(10);
        btns.setAlignment(Pos.CENTER);

        Button yesBtn = new Button("Yes, Delete");
        yesBtn.getStyleClass().add("btn-danger");
        yesBtn.setOnAction(e -> {
            database.remove(art);
            renderArticles();
            mainContainer.setRight(null);
            confirmStage.close();
        });

        Button noBtn = new Button("Cancel");
        noBtn.getStyleClass().add("btn-dark");
        noBtn.setOnAction(e -> confirmStage.close());

        btns.getChildren().addAll(yesBtn, noBtn);
        box.getChildren().addAll(warning, btns);

        Scene s = new Scene(box, 350, 150);
        s.getStylesheets().add(getCssDataUri());
        confirmStage.setScene(s);
        confirmStage.show();
    }

    private void handleLockboxToggle() {
        if (isEditorMode) {
            isEditorMode = false;
            updateStats();
            renderArticles();
            mainContainer.setRight(null);
            return;
        }

        Stage authStage = new Stage();
        authStage.initModality(Modality.APPLICATION_MODAL);

        VBox box = new VBox(12);
        box.setPadding(new Insets(20));
        box.setAlignment(Pos.CENTER);
        box.getStyleClass().add("root-pane");

        Label label = new Label("Enter Editorial Lockbox Password");
        label.getStyleClass().add("card-title");

        PasswordField pf = new PasswordField();
        pf.getStyleClass().add("search-field");
        pf.setPromptText("Password");

        Label errorLabel = new Label("Invalid Key.");
        errorLabel.getStyleClass().add("error-text");
        errorLabel.setVisible(false);

        Button submitBtn = new Button("Unlock");
        submitBtn.getStyleClass().add("btn-gold");
        submitBtn.setOnAction(e -> {
            if ("hirablog2k26".equals(pf.getText())) {
                isEditorMode = true;
                updateStats();
                renderArticles();
                authStage.close();
            } else {
                errorLabel.setVisible(true);
            }
        });

        box.getChildren().addAll(label, pf, errorLabel, submitBtn);

        Scene s = new Scene(box, 300, 180);
        s.getStylesheets().add(getCssDataUri());
        authStage.setScene(s);
        authStage.show();
    }

    private void openWriteModal() {
        Stage writeStage = new Stage();
        writeStage.initModality(Modality.APPLICATION_MODAL);

        VBox root = new VBox(12);
        root.setPadding(new Insets(20));
        root.getStyleClass().add("root-pane");

        Label mainTitle = new Label("Compose Literature Piece");
        mainTitle.getStyleClass().add("drawer-title");

        TextField titleField = new TextField();
        titleField.setPromptText("Composition Title");
        titleField.getStyleClass().add("search-field");

        TextField authorField = new TextField();
        authorField.setPromptText("Author Name");
        authorField.getStyleClass().add("search-field");

        ComboBox<String> langBox = new ComboBox<>();
        langBox.getItems().addAll("English", "മലയാളം", "العربية", "اردو", "हिन्दी");
        langBox.setValue("English");
        langBox.getStyleClass().add("search-field");

        ComboBox<String> litBox = new ComboBox<>();
        litBox.getItems().addAll("Poem", "Story", "Essay", "Feature", "Another");
        litBox.setValue("Essay");
        litBox.getStyleClass().add("search-field");

        TextArea descArea = new TextArea();
        descArea.setPromptText("Short Abstract / Preview...");
        descArea.setPrefHeight(60);
        descArea.getStyleClass().add("drawer-content-area");

        TextArea contentArea = new TextArea();
        contentArea.setPromptText("Full text of Publication...");
        contentArea.getStyleClass().add("drawer-content-area");
        VBox.setVgrow(contentArea, Priority.ALWAYS);

        Button submitBtn = new Button("Submit & Publish");
        submitBtn.getStyleClass().add("btn-gold");
        submitBtn.setOnAction(e -> {
            if (titleField.getText().trim().isEmpty() || authorField.getText().trim().isEmpty() || contentArea.getText().trim().isEmpty()) {
                Alert alert = new Alert(Alert.AlertType.WARNING, "All crucial fields must be filled!");
                alert.show();
                return;
            }

            Article na = new Article();
            na.id = String.valueOf(System.currentTimeMillis());
            na.title = titleField.getText().trim();
            na.author = authorField.getText().trim();
            na.category = "Literary Corner";
            na.language = getLangCode(langBox.getValue());
            na.litType = litBox.getValue();
            na.abstractText = descArea.getText().trim();
            na.content = contentArea.getText().trim();
            na.status = "published";
            na.readTime = 5;
            na.date = new SimpleDateFormat("MMMM dd, yyyy").format(new Date());

            database.add(0, na);
            renderArticles();
            writeStage.close();
        });

        root.getChildren().addAll(mainTitle, titleField, authorField, langBox, litBox, descArea, contentArea, submitBtn);

        Scene s = new Scene(root, 500, 550);
        s.getStylesheets().add(getCssDataUri());
        writeStage.setScene(s);
        writeStage.show();
    }

    private String getLangCode(String fullLang) {
        switch (fullLang) {
            case "മലയാളം": return "ML";
            case "العربية": return "AR";
            case "اردو": return "UR";
            case "हिन्दी": return "HI";
            default: return "EN";
        }
    }

    private void updateStats() {
        long count = database.stream().filter(a -> "published".equalsIgnoreCase(a.status)).count();
        statCountLabel.setText("Writings: " + count);
        bookmarkCountLabel.setText("Bookmarks: " + bookmarkedIds.size());
        lockboxStatusLabel.setText("Editor Mode: " + (isEditorMode ? "Unlocked" : "Locked"));
    }

    private void seedInitialDatabase() {
        database.add(new Article("1", "Contemplating the Silence: Epistemic Solitude and the Mind", 
                "Dr. Arthur Vance", "Academic Studies", "Essay", "EN", "published",
                "An analytical inquiry exploring intellectual isolation ('Contemplation') as a foundational component for cognitive restoration.",
                "Contemplation is not merely a state of physical quietude, but a profound architecture of the human intellect. In our contemporary digital acceleration, we have systematically traded depth for convenience. By examining the historical framework of intellectual hermits and academic isolation, we explore how isolation serves as the absolute matrix for critical theory.", 10, "June 17, 2026"));

        

