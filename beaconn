    }

    public static class Article {
        public String id;
        public String title;
        public String author;
        public String category;
        public String litType;
        public String language;
        public String status;
        public String abstractText;
        public String content;
        public int readTime;
        public String date;

        public Article() {}

        public Article(String id, String title, String author, String category, String litType, String language, String status, String abstractText, String content, int readTime, String date) {
            this.id = id;
            this.title = title;
            this.author = author;
            this.category = category;
            this.litType = litType;
            this.language = language;
            this.status = status;
            this.abstractText = abstractText;
            this.content = content;
            this.readTime = readTime;
            this.date = date;
        }
    }

    public static void main(String[] args) {
        launch(args);
    }
}
