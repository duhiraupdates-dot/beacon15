<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hira Beacon — Journal of Academic & Creative Inquiry</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Elegant Editorial & Classical Serifs -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;950&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,300&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Fraunces', 'serif'],
                        display: ['Cinzel', 'serif'],
                        editorial: ['Playfair Display', 'serif'],
                        mono: ['Fira Code', 'monospace']
                    },
                    colors: {
                        darkBg: '#030303',
                        darkCard: '#08080b',
                        darkBorder: '#121217',
                        lightBg: '#faf9f5',
                        lightCard: '#ffffff',
                        lightBorder: '#e8e6df',
                        accentGold: '#d4af37',
                        accentGoldHover: '#b5942e',
                        accentAmber: '#f59e0b',
                    },
                    boxShadow: {
                        'neon-sm': '0 0 10px rgba(212, 175, 55, 0.15)',
                        'neon-md': '0 0 20px rgba(212, 175, 55, 0.3)',
                        'neon-lg': '0 0 40px rgba(212, 175, 55, 0.5)',
                        'inner-gold': 'inset 0 0 15px rgba(212, 175, 55, 0.08)',
                    }
                }
            }
        }
    </script>
    
    <style>
        /* Premium Gold Glow Accent Guides */
        .glow-line-gold {
            height: 1px;
            background: linear-gradient(90deg, transparent, #d4af37, #f59e0b, #d4af37, transparent);
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.5), 0 0 20px rgba(212, 175, 55, 0.2);
            position: relative;
        }
        
        .glow-line-gold::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 6px;
            height: 6px;
            background: #f59e0b;
            border-radius: 50%;
            box-shadow: 0 0 10px #d4af37, 0 0 20px #d4af37;
        }

        .glow-border-gold {
            position: relative;
            border-color: rgba(212, 175, 55, 0.12) !important;
            box-shadow: 0 0 12px rgba(212, 175, 55, 0.03);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .glow-border-gold:hover {
            border-color: rgba(212, 175, 55, 0.5) !important;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.2), inset 0 0 10px rgba(212, 175, 55, 0.04);
            transform: translateY(-2px);
        }

        /* Pulsing Background Nebulas */
        @keyframes pulseGlow {
            0%, 100% { transform: scale(1); opacity: 0.1; filter: blur(80px); }
            50% { transform: scale(1.1); opacity: 0.16; filter: blur(100px); }
        }
        .beacon-glow {
            animation: pulseGlow 14s infinite ease-in-out;
        }

        /* Scholastic Dropcap Style */
        .academic-dropcap::first-letter {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            float: left;
            font-size: 3em;
            line-height: 0.8;
            margin: 4px 8px 0px 0;
            color: #d4af37;
            text-shadow: 0 0 8px rgba(212, 175, 55, 0.25);
        }

        @keyframes blink {
            50% { border-color: transparent }
        }
        .typing-cursor {
            border-right: 2.5px solid #d4af37;
            animation: blink 0.75s step-end infinite;
        }

        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }
        .dark ::-webkit-scrollbar-track {
            background: #030303;
        }
        .dark ::-webkit-scrollbar-thumb {
            background: #121216;
            border-radius: 999px;
            border: 1px solid rgba(212,175,55,0.08);
        }
        .dark ::-webkit-scrollbar-thumb:hover {
            background: #d4af37;
        }
        
        .asymmetric-pattern {
            background-size: 80px 80px;
            background-image: radial-gradient(circle, rgba(212, 175, 55, 0.02) 1px, transparent 1px);
        }
    </style>
</head>
<body class="bg-lightBg text-zinc-800 dark:bg-darkBg dark:text-zinc-200 font-sans min-h-screen relative overflow-x-hidden transition-colors duration-300 asymmetric-pattern">

    <!-- REUSABLE GOLD BEACON EMBLEM SVG -->
    <div class="hidden">
        <svg id="hiraLogoSvg" viewBox="0 0 100 100" class="w-full h-full text-amber-500 dark:text-amber-400 fill-current">
            <circle cx="50" cy="50" r="46" fill="none" stroke="currentColor" stroke-width="0.75" stroke-dasharray="3 3" opacity="0.4"/>
            <circle cx="50" cy="50" r="42" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.8"/>
            <circle cx="50" cy="50" r="38" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 5" opacity="0.6"/>
            <path d="M 22 72 L 40 44 L 50 54 L 62 38 L 78 72 Z" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
            <path d="M 32 72 L 40 58 L 48 66 L 56 50 L 68 72 Z" fill="currentColor" opacity="0.15"/>
            <path d="M 24 75 C 37 68, 48 74, 50 76 C 52 74, 63 68, 76 75" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="50" y1="76" x2="50" y2="82" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <polygon points="50,38 43,15 57,15" fill="currentColor" opacity="0.15"/>
            <line x1="50" y1="38" x2="50" y2="10" stroke="currentColor" stroke-width="1.5" stroke-dasharray="8 2"/>
            <g transform="translate(50, 10)">
                <path d="M 0,-8 L 2.5,-2.5 L 8,0 L 2.5,2.5 L 0,8 L -2.5,2.5 L -8,0 L -2.5,-2.5 Z" fill="currentColor"/>
                <circle cx="0" cy="0" r="1.5" fill="white"/>
            </g>
        </svg>
    </div>

    <!-- PORTAL SPLASH INTRO SCREEN -->
    <div id="splashScreen" class="fixed inset-0 bg-[#030303] z-[9999] flex flex-col items-center justify-center transition-all duration-700">
        <div class="text-center flex flex-col items-center px-6 max-w-md relative select-none">
            <div class="absolute -inset-14 bg-amber-500/10 rounded-full blur-3xl beacon-glow animate-pulse"></div>
            
            <div class="w-24 h-24 rounded-full border border-amber-500/30 bg-zinc-950 flex items-center justify-center shadow-neon-md relative mb-8 cursor-pointer hover:scale-105 transition-all" onclick="dismissSplash()">
                <div class="w-18 h-18">
                    <svg viewBox="0 0 100 100" class="w-full h-full text-amber-400 fill-current">
                        <use href="#hiraLogoSvg"/>
                    </svg>
                </div>
                <span class="absolute -top-0.5 -right-0.5 flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-550"></span>
                </span>
            </div>
            
            <div class="h-10 flex items-center justify-center mb-6">
                <h1 id="welcomeTypewriter" class="text-xl sm:text-2xl font-display uppercase tracking-[0.25em] text-white typing-cursor pr-1"></h1>
            </div>
            
            <div class="w-32 h-[1px] bg-zinc-900 overflow-hidden relative mb-4">
                <div class="absolute top-0 left-0 h-full w-full bg-gradient-to-r from-amber-500 via-yellow-400 to-amber-600 animate-[shimmer_1.5s_infinite]"></div>
            </div>
            <p class="text-[9px] text-zinc-500 font-mono tracking-widest uppercase">Acquiring Catalog Directories</p>
        </div>
    </div>

    <!-- Ambient Glow Drops -->
    <div class="absolute top-0 left-1/4 -translate-x-1/2 w-[600px] h-[600px] bg-amber-500/5 dark:bg-amber-950/10 rounded-full beacon-glow pointer-events-none z-0"></div>
    <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-yellow-500/5 dark:bg-yellow-950/10 rounded-full beacon-glow pointer-events-none z-0"></div>

    <!-- TOP MODERATOR ACTIVE DESK BANNER -->
    <div id="editorBanner" class="hidden bg-zinc-950 text-white text-xs py-2 px-4 border-b border-amber-900/20 text-center relative z-40 transition-all shadow-neon-sm">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
            <span class="flex items-center gap-2 text-left">
                <span class="w-2 h-2 rounded-full bg-amber-400 animate-ping"></span>
                <span class="font-mono text-[10px] tracking-wider uppercase text-amber-400 font-bold">Editorial Desk Active — Moderation Panel Enabled</span>
            </span>
            <div class="flex items-center gap-2 shrink-0">
                <button onclick="triggerPurgeDirectory()" class="px-2.5 py-1 bg-red-950/45 hover:bg-red-900 text-red-400 hover:text-white rounded border border-red-900/30 text-[9px] uppercase font-mono tracking-wider transition-all">
                    <i class="fa-solid fa-dumpster-fire mr-1"></i> Purge All
                </button>
                <button onclick="exitEditorMode()" class="px-2.5 py-1 bg-zinc-900 hover:bg-zinc-800 rounded border border-zinc-850 text-[9px] uppercase font-mono tracking-wider transition-all">
                    <i class="fa-solid fa-lock mr-1"></i> Lock Desk
                </button>
            </div>
        </div>
    </div>

    <!-- MAIN APPLICATION CONTAINER -->
    <div id="app" class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col min-h-screen">
        
        <!-- ABSOLUTE STANDALONE TOP LOGO (CAPTION-FREE MEDALLION) -->
        <div class="flex justify-center mt-6 mb-4">
            <div class="w-20 h-20 rounded-full border border-amber-500/20 dark:border-amber-500/40 bg-white dark:bg-zinc-950 flex items-center justify-center shadow-neon-sm hover:scale-105 transition-transform duration-300 cursor-pointer" onclick="resetFilters()">
                <div class="w-16 h-16">
                    <svg viewBox="0 0 100 100" class="w-full h-full text-amber-500 dark:text-amber-400 fill-current">
                        <use href="#hiraLogoSvg"/>
                    </svg>
                </div>
            </div>
        </div>

        <!-- HEADER SECTION & METADATA BRANDING -->
        <header class="border-b border-zinc-200 dark:border-zinc-900 pb-6 mb-8 text-center">
            
            <div class="max-w-2xl mx-auto mb-6">
                <p class="text-[9px] tracking-[0.3em] text-amber-600 dark:text-amber-400 uppercase font-bold">Volume IV • Issue II</p>
                <h1 class="text-3xl sm:text-4xl font-display font-black uppercase tracking-[0.15em] text-zinc-950 dark:text-white mt-1 leading-none">
                    Hira Beacon
                </h1>
                <p class="text-xs text-zinc-500 dark:text-zinc-400 font-serif italic mt-2.5 leading-relaxed">
                    A critical international platform of academic reviews, contemporary prose, and creative essays. Built for focused readings.
                </p>
            </div>

            <!-- PRIMARY CATEGORIES SWITCHBOARD -->
            <div class="flex flex-col gap-6 pt-2">
                <!-- Center Positioned Languages Bar (image_19bce8.png) -->
                <div class="flex flex-col gap-1.5 items-center justify-center">
                    <span class="text-[9px] font-mono font-bold text-amber-600 dark:text-amber-400 uppercase tracking-widest flex items-center justify-center gap-1.5">
                        <i class="fa-solid fa-globe text-[9px]"></i> Languages:
                    </span>
                    <div class="flex items-center justify-center gap-1.5 overflow-x-auto pb-1 max-w-full -mx-4 px-4 sm:mx-0 sm:px-0">
                        <button onclick="selectLanguage('All')" class="lang-tab active px-3.5 py-1.5 bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lang="All">
                            All Editions
                        </button>
                        <button onclick="selectLanguage('EN')" class="lang-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lang="EN">
                            English
                        </button>
                        <button onclick="selectLanguage('ML')" class="lang-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lang="ML">
                            മലയാളം
                        </button>
                        <button onclick="selectLanguage('AR')" class="lang-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lang="AR">
                            العربية
                        </button>
                        <button onclick="selectLanguage('UR')" class="lang-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lang="UR">
                            اردو
                        </button>
                        <button onclick="selectLanguage('HI')" class="lang-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lang="HI">
                            हिन्दी
                        </button>
                    </div>
                </div>

                <!-- Center Positioned Literary Styles Bar (image_19c08a.png) -->
                <div class="flex flex-col gap-1.5 items-center justify-center border-t border-zinc-100 dark:border-zinc-900/60 pt-4">
                    <span class="text-[9px] font-mono font-bold text-amber-600 dark:text-amber-400 uppercase tracking-widest flex items-center justify-center gap-1.5">
                        📜 Literary Styles:
                    </span>
                    <div class="flex items-center justify-center gap-1.5 overflow-x-auto pb-1 max-w-full -mx-4 px-4 sm:mx-0 sm:px-0">
                        <button onclick="selectLitType('All')" class="lit-tab active px-3.5 py-1.5 bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lit="All">
                            All Styles
                        </button>
                        <button onclick="selectLitType('Poem')" class="lit-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lit="Poem">
                            Poems
                        </button>
                        <button onclick="selectLitType('Story')" class="lit-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lit="Story">
                            Short Stories
                        </button>
                        <button onclick="selectLitType('Essay')" class="lit-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lit="Essay">
                            Critical Essays
                        </button>
                        <button onclick="selectLitType('Feature')" class="lit-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lit="Feature">
                            Features & Reports
                        </button>
                        <button onclick="selectLitType('Another')" class="lit-tab px-3.5 py-1.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-100 rounded text-xs font-semibold whitespace-nowrap transition-all duration-150" data-lit="Another">
                            Miscellany
                        </button>
                    </div>
                </div>
            </div>

            <!-- Operational Control HUD -->
            <div class="flex flex-wrap items-center gap-2 justify-center mt-6">
                <!-- Theme toggle switch -->
                <button onclick="toggleTheme()" class="p-2 bg-white dark:bg-zinc-950 hover:bg-zinc-100 dark:hover:bg-zinc-900 border border-zinc-200 dark:border-zinc-900 text-zinc-650 dark:text-zinc-400 rounded-lg transition-all shadow-sm" title="Toggle theme mode">
                    <i id="themeIcon" class="fa-solid fa-moon"></i>
                </button>

                <!-- Responsive search input bar -->
                <div class="relative w-full sm:w-56">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-amber-500">
                        <i class="fa-solid fa-magnifying-glass text-[10px]"></i>
                    </span>
                    <input type="text" id="searchInput" oninput="handleSearch(this.value)" placeholder="Search catalog..." 
                           class="w-full bg-white dark:bg-zinc-950 text-xs text-zinc-800 dark:text-zinc-100 placeholder-zinc-400 dark:placeholder-zinc-500 rounded-lg pl-8 pr-3 py-2.5 border border-zinc-200 dark:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-amber-500 transition-all">
                </div>

                <!-- Custom bookmarks filter toggle -->
                <button onclick="toggleBookmarkFilter()" id="bookmarkFilterBtn" 
                        class="px-3.5 py-2.5 bg-white dark:bg-zinc-950 hover:bg-zinc-100 dark:hover:bg-zinc-900 border border-zinc-200 dark:border-zinc-900 text-zinc-600 dark:text-zinc-400 rounded-lg text-xs flex items-center gap-2 transition-all shadow-sm">
                    <i class="fa-regular fa-bookmark text-amber-500" id="bookmarkFilterIcon"></i>
                    <span>Bookmarks</span>
                    <span id="bookmarkBadge" class="bg-amber-500/10 text-amber-600 dark:text-amber-400 text-[9px] px-1.5 py-0.5 rounded font-mono hidden font-bold">0</span>
                </button>

                <!-- Editorial security key portal gate -->
                <button onclick="openPasswordModal()" id="editorControlBtn" 
                        class="px-3.5 py-2.5 bg-white dark:bg-zinc-950 hover:bg-zinc-100 dark:hover:bg-zinc-900 border border-zinc-200 dark:border-zinc-900 text-zinc-650 dark:text-zinc-400 rounded-lg text-xs flex items-center gap-2 transition-all font-mono shadow-sm">
                    <i class="fa-solid fa-key text-amber-500" id="editorLockIcon"></i>
                    <span id="editorBtnText">Lockbox</span>
                </button>

                <!-- Free publication writer desk trigger -->
                <button onclick="triggerPublishAction()" class="px-4 py-2.5 bg-amber-600 hover:bg-amber-500 text-white font-medium rounded-lg text-xs flex items-center gap-2 transition-all shadow-neon-sm active:scale-95">
                    <i class="fa-solid fa-pen-nib text-[10px]"></i>
                    <span>Write Post</span>
                </button>
            </div>
        </header>

        <!-- PREMIUM SHIMMERING GLOW SEPARATOR -->
        <div class="glow-line-gold mb-10"></div>

        <!-- PENDING MODERATION DESK (LOCKBOX SECURED QUEUE) -->
        <section id="moderationQueueSection" class="hidden mb-12 bg-amber-50/20 dark:bg-amber-950/10 border border-amber-500/20 rounded-xl p-6 relative overflow-hidden transition-all duration-300 shadow-neon-sm">
            <div class="absolute -right-20 -top-20 w-44 h-44 bg-amber-500/5 rounded-full blur-2xl pointer-events-none"></div>
            <div class="flex items-center justify-between border-b border-amber-500/10 pb-4 mb-4">
                <div class="flex items-center gap-2">
                    <span class="w-3.5 h-3.5 bg-amber-500 rounded-full animate-pulse shadow-neon-md flex items-center justify-center">
                        <i class="fa-solid fa-lock text-[8px] text-zinc-950"></i>
                    </span>
                    <h3 class="text-xs font-display font-bold tracking-widest text-amber-500 uppercase">Lockbox Submission Queue</h3>
                </div>
                <span class="text-[9px] font-mono bg-amber-500/20 text-amber-400 px-2.5 py-0.5 rounded-full border border-amber-500/30" id="pendingCounter">0 Pending Articles</span>
            </div>
            
            <p class="text-xs text-zinc-500 dark:text-zinc-400 font-serif italic max-w-2xl mb-4">
                Articles submitted by readers are held securely in this pending moderation lockbox. Unlock to review, edit, approve, or discard permanently.
            </p>

            <div id="pendingQueueContainer" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Injected dynamically in editor authentication modes -->
            </div>
        </section>

        <!-- PORTAL DIRECTORY VIEW CONTROLS -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-6 gap-3">
            <div>
                <h3 class="text-sm font-display uppercase tracking-widest text-zinc-900 dark:text-white flex items-center gap-2">
                    <span class="inline-block w-1.5 h-1.5 bg-amber-500 rounded-full animate-pulse shadow-neon-sm"></span>
                    <span id="currentSelectionIndicator" class="font-bold">Journal Catalogue</span>
                </h3>
                <p class="text-[9px] font-mono uppercase text-zinc-400 tracking-wider mt-0.5" id="resultsCount">Loading documents...</p>
            </div>
            
            <div class="flex items-center gap-1.5 self-end">
                <button onclick="setLayout('asymmetric')" id="btnAsym" class="px-3 py-2 bg-white dark:bg-zinc-950 hover:bg-zinc-100 dark:hover:bg-zinc-900 text-amber-600 dark:text-amber-400 border border-zinc-200 dark:border-zinc-900 rounded text-xs flex items-center gap-1 transition-all shadow-sm" title="Asymmetrical Grid view">
                    <i class="fa-solid fa-shapes text-xs"></i>
                    <span class="text-[9px] uppercase font-mono font-bold">Asymmetrical Grid</span>
                </button>
                <button onclick="setLayout('list')" id="btnList" class="p-2 bg-white dark:bg-zinc-950 hover:bg-zinc-100 dark:hover:bg-zinc-900 text-zinc-400 dark:text-zinc-500 border border-zinc-200 dark:border-zinc-900 rounded transition-all shadow-sm" title="Standard list list view">
                    <i class="fa-solid fa-list text-xs"></i>
                </button>
            </div>
        </div>

        <!-- MAIN POST CONTAINER -->
        <main class="flex-1">
            <div id="postsContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 transition-all duration-300">
                <!-- Managed dynamically by system templates -->
            </div>

            <!-- EMPTY DATABASE VIEW -->
            <div id="emptyState" class="hidden py-16 text-center max-w-sm mx-auto">
                <div class="w-12 h-12 rounded-full bg-zinc-100 dark:bg-zinc-900 flex items-center justify-center text-zinc-400 dark:text-zinc-600 mx-auto mb-4 border border-zinc-200 dark:border-zinc-800">
                    <i class="fa-solid fa-book-bookmark text-lg text-amber-500"></i>
