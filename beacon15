        async function handlePublishSubmit(event) {
            event.preventDefault();

            const editId = document.getElementById('editPostId').value;
            const title = document.getElementById('postTitle').value;
            const author = document.getElementById('postAuthor').value;
            const category = document.getElementById('postCategory').value;
            const language = document.getElementById('postLanguage').value;
            const litType = document.getElementById('postLitType').value;
            const abstract = document.getElementById('postAbstract').value;
            const content = document.getElementById('postContent').value;
            const readTime = parseInt(document.getElementById('postReadTime').value);
            const imageBase64 = document.getElementById('postPhotoBase64').value;

            const statusType = editId ? (posts.find(p => String(p.id) === String(editId))?.status || 'published') : 'pending';

            const postData = {
                title: title,
                author: author,
                category: category,
                language: language,
                litType: litType,
                abstract: abstract,
                content: content,
                readTime: readTime,
                status: statusType,
                image: imageBase64
            };

            if (editId) {
                if (db && auth && auth.currentUser) {
                    try {
                        const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'posts', String(editId));
                        await updateDoc(docRef, postData);
                        showToast("Revisions uploaded.");
                    } catch(e) {
                        console.error("Firestore update failed:", e);
                        showToast("Database communication failure.");
                    }
                } else {
                    const postIdx = posts.findIndex(p => String(p.id) === String(editId));
                    if (postIdx !== -1) {
                        posts[postIdx] = { ...posts[postIdx], ...postData };
                        saveDatabase();
                        renderPosts();
                        renderPendingQueue();
                        showToast("Revisions saved locally.");
                    }
                }
            } else {
                const newId = String(Date.now());
                const newPost = {
                    id: newId,
                    ...postData,
                    date: new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
                    featured: false
                };

                if (db && auth && auth.currentUser) {
                    try {
                        const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'posts', newId);
                        await setDoc(docRef, newPost);
                        showToast("Submitted successfully to Lockbox.");
                    } catch(e) {
                        console.error("Firestore upload failed:", e);
                        showToast("Failed to upload entry.");
                    }
                } else {
                    posts.push(newPost);
                    saveDatabase();
                    renderPosts();
                    renderPendingQueue();
                    showToast("Submitted successfully to Lockbox.");
                }
            }

            closePublishModal();
            updateStats();
        }

        function saveDatabase() {
            safeSetLocalItem('hira_posts_db', JSON.stringify(posts));
        }

        // PERMANENT DELETIONS (SYNCS GLOBALLY)
        function confirmDeletePost(id, event) {
            if (event) event.stopPropagation();
            
            triggerCustomConfirm(
                "Delete Publication Permanently", 
                "Warning: This action will permanently delete this document from all desktops and devices globally.", 
                () => {
                    executeDeletePost(id);
                }
            );
        }

        async function executeDeletePost(id) {
            posts = posts.filter(p => String(p.id) !== String(id));

            if (db && auth && auth.currentUser) {
                try {
                    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'posts', String(id));
                    await deleteDoc(docRef);
                    showToast("Article deleted permanently across all devices!");
                } catch(e) {
                    console.error("Firestore global deletion failed:", e);
                    showToast("Failed to delete globally from cloud.");
                }
            } else {
                saveDatabase();
                renderPosts();
                renderPendingQueue();
                showToast("Deleted locally.");
            }
            
            savedPostIds = savedPostIds.filter(savedId => String(savedId) !== String(id));
            safeSetLocalItem('hira_bookmarks_db', JSON.stringify(savedPostIds));

            renderPosts();
            renderPendingQueue();
            updateStats();
        }

        // SYSTEM DIRECTORY PURGES
        function triggerPurgeDirectory() {
            triggerCustomConfirm(
                "Purge Entire Directory", 
                "Crucial Warning: This deletes ALL records and custom publications globally. No backups are saved.", 
                () => {
                    executePurgeDirectory();
                }
            );
        }

        async function executePurgeDirectory() {
            posts = [];
            savedPostIds = [];
            safeSetLocalItem('hira_bookmarks_db', JSON.stringify(savedPostIds));

            if (db && auth && auth.currentUser) {
                try {
                    const postsCol = collection(db, 'artifacts', appId, 'public', 'data', 'posts');
                    const snapshot = await getDocs(postsCol);
                    for (const docSnap of snapshot.docs) {
                        await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'posts', docSnap.id));
                    }
                    showToast("System database purged globally.");
                } catch(e) {
                    console.error("Cloud purge failed:", e);
                    showToast("Purge failed.");
                }
            } else {
                saveDatabase();
                renderPosts();
                renderPendingQueue();
                showToast("Local storage purged.");
            }
            
            resetFilters();
            updateStats();
        }

        // RESTORE DEFAULTS
        async function restoreSeedDatabase() {
            if (db && auth && auth.currentUser) {
                try {
                    for (const seed of SEED_POSTS) {
                        const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'posts', seed.id);
                        await setDoc(docRef, seed);
                    }
                    showToast("Defaults restored successfully across all devices.");
                } catch(e) {
                    console.error("Seeding cloud documents failed:", e);
                    showToast("Seeding failed.");
                }
            } else {
                posts = [...SEED_POSTS];
                saveDatabase();
                renderPosts();
                renderPendingQueue();
                showToast("Defaults restored.");
            }
            updateStats();
        }

