                                    ${isEditorModeActive ? `
                                        <button onclick="openEditPost('${post.id}', event)" class="p-1.5 bg-zinc-50 dark:bg-zinc-900 text-amber-600 hover:bg-amber-550/10 border border-zinc-150 dark:border-zinc-850 rounded transition-colors">
