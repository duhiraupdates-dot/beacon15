        let isInstalling = false;
        function startSimulatedApkInstall() {
            if (isInstalling) return;
            isInstalling = true;

            const btn = document.getElementById('apkInstallBtn');
            const resetBtn = document.getElementById('apkResetBtn');
            const idleState = document.getElementById('apkStateIdle');
            const progressState = document.getElementById('apkStateProgress');
            const successState = document.getElementById('apkStateSuccess');
            const progressBar = document.getElementById('apkProgressBar');
            const percentLabel = document.getElementById('apkPercent');
            const stageLabel = document.getElementById('apkInstallStage');
            const subtext = document.getElementById('apkSubtext');

            btn.disabled = true;
            btn.classList.add('opacity-50', 'cursor-not-allowed');

            idleState.classList.add('hidden');
            successState.classList.add('hidden');
            progressState.classList.remove('hidden');

            let progress = 0;
            progressBar.style.width = '0%';
            percentLabel.innerText = '0%';

            const interval = setInterval(() => {
                progress += Math.floor(Math.random() * 8) + 4;
                if (progress > 100) progress = 100;

                progressBar.style.width = `${progress}%`;
                percentLabel.innerText = `${progress}%`;

                if (progress < 25) {
                    stageLabel.innerText = "Downloading...";
                    subtext.innerText = `Fetching APK components (${(progress * 18.4 / 100).toFixed(1)} MB / 18.4 MB)`;
                } else if (progress < 55) {
                    stageLabel.innerText = "Verifying Integrity...";
                    subtext.innerText = "Running Flutter target platform package validations...";
                } else if (progress < 80) {
                    stageLabel.innerText = "Decompressing Assets...";
                    subtext.innerText = "Configuring rendering engines and custom typography layouts...";
                } else if (progress < 100) {
                    stageLabel.innerText = "Installing Application...";
                    subtext.innerText = "Resolving sandbox storage layers onto your device directory...";
                } else {
                    clearInterval(interval);
                    setTimeout(() => {
                        progressState.classList.add('hidden');
                        successState.classList.remove('hidden');
                        resetBtn.classList.remove('hidden');
                        
                        btn.innerHTML = `<i class="fa-solid fa-mobile-screen-button"></i> <span>Installation Finished</span>`;
                        isInstalling = false;
                        showToast("Simulated APK compilation complete!");
                    }, 500);
                }
            }, 100);
        }

        function resetApkSim() {
            const btn = document.getElementById('apkInstallBtn');
            const resetBtn = document.getElementById('apkResetBtn');
            const idleState = document.getElementById('apkStateIdle');
            const progressState = document.getElementById('apkStateProgress');
            const successState = document.getElementById('apkStateSuccess');

            btn.disabled = false;
            btn.classList.remove('opacity-50', 'cursor-not-allowed');
            btn.innerHTML = `<i class="fa-brands fa-android"></i> <span>Start Flutter Compilation</span>`;

            idleState.classList.remove('hidden');
            progressState.classList.add('hidden');
            successState.classList.add('hidden');
            resetBtn.classList.add('hidden');
            isInstalling = false;
        }

