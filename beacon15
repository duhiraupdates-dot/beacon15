                                        </button>
                                        <button onclick="confirmDeletePost('${post.id}', event)" class="p-1.5 bg-zinc-50 dark:bg-zinc-900 text-red-500 hover:bg-red-550/10 border border-zinc-150 dark:border-zinc-850 rounded transition-colors">
                                            <i class="fa-solid fa-trash-can text-[10px]"></i>
                                        </button>
                                    ` : ''}
                                    <button onclick="openReadPost('${post.id}')" class="px-3.5 py-1.5 bg-zinc-900 dark:bg-zinc-100 hover:bg-zinc-800 dark:hover:bg-zinc-200 text-xs text-white dark:text-zinc-900 rounded font-semibold transition-all shadow-sm">
                                        Open
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                }
            });

            container.innerHTML = htmlContent;
        }

        function renderPendingQueue() {
            const container = document.getElementById('pendingQueueContainer');
            const pendingCounter = document.getElementById('pendingCounter');
            if (!container) return;

            const pending = posts.filter(p => p.status === 'pending');
            pendingCounter.innerText = `${pending.length} Pending Submission${pending.length === 1 ? '' : 's'}`;

            if (pending.length === 0) {
                container.innerHTML = `
                    <div class="col-span-full py-8 text-center border border-dashed border-amber-500/20 rounded-lg">
                        <p class="text-xs font-mono text-amber-500/60 uppercase">No items currently waiting in review queue</p>
                    </div>
                `;
                return;
            }

            let pendingHtml = "";
            pending.forEach(post => {
                const typography = getLanguageTypographyStyles(post.language);
                pendingHtml += `
                    <div class="bg-zinc-900/60 border border-amber-500/30 rounded-lg p-4 flex flex-col justify-between gap-3 relative shadow-sm animate-pulse">
                        <div>
                            <div class="flex items-center gap-1.5 mb-2">
                                <span class="bg-amber-500/10 text-amber-400 text-[8px] px-2 py-0.5 rounded font-mono font-bold">${post.language}</span>
                                <span class="bg-zinc-800 text-zinc-300 text-[8px] px-2 py-0.5 rounded font-mono">${post.litType}</span>
                                <span class="text-[8px] font-mono text-zinc-500 ml-auto">${post.date}</span>
                            </div>
                            <h4 class="${typography.heading} text-sm font-bold text-white mb-1 line-clamp-1">${post.title}</h4>
                            <p class="${typography.body} text-xs text-zinc-400 line-clamp-2 italic">${post.abstract}</p>
                            <span class="text-[9px] font-mono text-amber-500 mt-2 block">By: ${post.author}</span>
                        </div>
                        
                        <div class="flex items-center gap-2 pt-2 border-t border-zinc-800 text-xs">
                            <button onclick="openReadPost('${post.id}')" class="px-2.5 py-1 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 rounded text-[10px] font-semibold flex items-center gap-1">
                                <i class="fa-regular fa-eye"></i> View Draft
                            </button>
                            <div class="flex items-center gap-1 ml-auto">
                                <button onclick="rejectPendingPost('${post.id}')" class="px-2.5 py-1 bg-red-950/40 hover:bg-red-900/40 text-red-400 rounded text-[10px] font-bold border border-red-900/30">
                                    <i class="fa-regular fa-trash-can mr-1"></i> Decline
                                </button>
                                <button onclick="approvePendingPost('${post.id}')" class="px-3 py-1 bg-amber-600 hover:bg-amber-550 text-white rounded text-[10px] font-bold shadow-neon-sm">
                                    <i class="fa-solid fa-check mr-1"></i> Approve
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });

            container.innerHTML = pendingHtml;
        }

        async function approvePendingPost(id) {
            if (db && auth && auth.currentUser) {
                try {
                    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'posts', String(id));
                    await updateDoc(docRef, { status: 'published' });
                    showToast("Draft approved and published globally!");
                } catch(e) {
                    console.error("Firestore update failed:", e);
                    showToast("Database communication failure.");
                }
            } else {
                const idx = posts.findIndex(p => String(p.id) === String(id));
                if (idx !== -1) {
                    posts[idx].status = 'published';
                    saveDatabase();
                    renderPosts();
                    renderPendingQueue();
                    showToast("Draft published successfully!");
                }
            }
        }

        function rejectPendingPost(id) {
            triggerCustomConfirm(
                "Decline Submission",
                "Are you sure you want to decline and permanently discard this article?",
                async () => {
                    if (db && auth && auth.currentUser) {
                        try {
                            const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'posts', String(id));
                            await deleteDoc(docRef);
                            showToast("Submission declined.");
                        } catch(e) {
                            console.error("Firestore delete failed:", e);
                            showToast("Cloud deletion failed.");
                        }
                    } else {
                        posts = posts.filter(p => String(p.id) !== String(id));
                        saveDatabase();
                        renderPosts();
                        renderPendingQueue();
                        showToast("Submission discarded.");
                    }
                }
            );
        }

        function getLanguageTypographyStyles(langCode) {
            switch(langCode) {
                case 'AR': return { heading: 'font-serif font-bold', body: 'font-serif text-lg leading-loose' };
                case 'ML': return { heading: 'font-serif font-bold', body: 'font-serif leading-relaxed' };
                case 'UR': return { heading: 'font-serif font-bold leading-relaxed', body: 'font-serif leading-loose text-lg' };
                case 'HI': return { heading: 'font-serif font-bold', body: 'font-serif leading-relaxed' };
                default: return { heading: 'font-editorial font-bold', body: 'font-serif' };
            }
        }

        // BOOKMARKS PIPELINE
        function toggleSavePost(id, event) {
            if (event) event.stopPropagation();
            
            const stringId = String(id);
            const numberId = Number(id);

            let idx = savedPostIds.indexOf(stringId);
            if (idx === -1) idx = savedPostIds.indexOf(numberId);

            let toastMsg = "";

            if (idx === -1) {
                savedPostIds.push(stringId);
                toastMsg = "Saved to Bookmarks!";
            } else {
                savedPostIds.splice(idx, 1);
                toastMsg = "Removed from Bookmarks.";
            }

            safeSetLocalItem('hira_bookmarks_db', JSON.stringify(savedPostIds));
            renderPosts();
            updateStats();
            showToast(toastMsg);

            if (activeReadPost && String(activeReadPost.id) === stringId) {
                updateModalSaveButtonState(stringId);
            }
        }

        function toggleSaveFromModal() {
            if (activeReadPost) {
                toggleSavePost(activeReadPost.id, null);
            }
        }

        function updateModalSaveButtonState(id) {
            const btn = document.getElementById('modalSaveBtn');
            const stringId = String(id);
            const numberId = Number(id);

            if (btn && activeReadPost && String(activeReadPost.id) === stringId) {
                const isSaved = savedPostIds.includes(stringId) || savedPostIds.includes(numberId);
                btn.innerHTML = isSaved ? '<i class="fa-solid fa-bookmark text-amber-500 animate-[bounce_0.5s_1]"></i>' : '<i class="fa-regular fa-bookmark"></i>';
            }
        }

        // DOCUMENT READER DRAWER
        function openReadPost(id) {
            const post = posts.find(p => String(p.id) === String(id));
            if (!post) return;

            activeReadPost = post;

            document.getElementById('readModalCategory').innerText = post.category;
            document.getElementById('readModalLangBadge').innerText = post.language;
            document.getElementById('readModalTypeBadge').innerText = post.litType;
            document.getElementById('readerTitle').innerText = post.title;
            document.getElementById('readerAuthor').innerText = post.author;
            document.getElementById('readerMeta').innerText = `Published ${post.date} • ${post.readTime} min read`;
            document.getElementById('readerAvatar').innerHTML = `<span class="font-bold text-xs">${post.author.charAt(0)}</span>`;
            
            const coverContainer = document.getElementById('readerCoverImageContainer');
            const coverImg = document.getElementById('readerCoverImage');
            if (post.image && post.image.trim() !== "") {
                coverImg.src = post.image;
                coverContainer.classList.remove('hidden');
            } else {
                coverContainer.classList.add('hidden');
                coverImg.src = "";
            }

            const typography = getLanguageTypographyStyles(post.language);
            const bodyTextContainer = document.getElementById('readerBodyText');
            bodyTextContainer.className = `prose dark:prose-invert max-w-none text-zinc-700 dark:text-zinc-300 leading-relaxed font-serif space-y-5 text-sm ${typography.body}`;
            
            const textDir = post.language === 'AR' || post.language === 'UR' ? 'rtl' : 'ltr';
            bodyTextContainer.style.direction = textDir;
            if (post.language === 'AR' || post.language === 'UR') {
                bodyTextContainer.classList.add('text-right');
                bodyTextContainer.classList.remove('text-left');
            } else {
                bodyTextContainer.classList.add('text-left');
                bodyTextContainer.classList.remove('text-right');
            }

            const paragraphs = post.content.split('\n\n');
            let bodyHTML = "";
            paragraphs.forEach(p => {
                if (p.trim() !== "") {
                    bodyHTML += `<p class="leading-relaxed tracking-wide text-zinc-750 dark:text-zinc-300 text-sm md:text-base">${p}</p>`;
                }
            });
            bodyTextContainer.innerHTML = bodyHTML;
            bodyTextContainer.style.fontSize = `${readerFontSize}px`;

            updateModalSaveButtonState(id);

            const readEdit = document.getElementById('readerEditBtn');
            if (isEditorModeActive) {
                readEdit.classList.remove('hidden');
            } else {
                readEdit.classList.add('hidden');
            }

            const drawer = document.getElementById('readModal');
            drawer.classList.remove('translate-x-full', 'pointer-events-none');
            drawer.classList.add('translate-x-0');
